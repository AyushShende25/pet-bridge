@baseUrl = http://localhost:5000

### login
POST {{baseUrl}}/api/auth/sign-in/email
Content-Type: application/json

{
  "email": "admin@test.com",
  "password": "test1234"
}


### create shelter
POST {{baseUrl}}/api/shelters
Content-Type: application/json

{
  "name":"pet home",
  "address":"main chowk baner pune",
  "phone":"7247347747",
  "registration_number":"876543212",
  "latitude":18.5642,
  "longitude":73.7769
}

### get shelters
GET {{baseUrl}}/api/shelters?status=VERIFIED

### get shelter
GET {{baseUrl}}/api/shelters/67ddd7e8-5689-4d9b-8c67-09ce4a7694cd

### update shelter
PATCH {{baseUrl}}/api/shelters/67ddd7e8-5689-4d9b-8c67-09ce4a7694cd
Content-Type: application/json

{
  "name":"happy shelter",
  "address":"high street balewadi pune",
  # "phone":"",
  "latitude":18.582,
  "longitude":73.769
}

### delete shelter
DELETE {{baseUrl}}/api/shelters/67ddd7e8-5689-4d9b-8c67-09ce4a7694cd

### verify shelter
PATCH {{baseUrl}}/api/shelters/67ddd7e8-5689-4d9b-8c67-09ce4a7694cd/verification
Content-Type: application/json

{
  "verification_status":"VERIFIED"
}

### create species
POST {{baseUrl}}/api/species
Content-Type: application/json

{
  "name":"cat"
}

### get all species
GET {{baseUrl}}/api/species

### update species
PATCH {{baseUrl}}/api/species/8243b65a-76b2-4478-ba4a-79d1821d6240
Content-Type: application/json

{
  "name":"Doggos"
}

### delete species
DELETE {{baseUrl}}/api/species/8243b65a-76b2-4478-ba4a-79d1821d6240

### create breeds
POST {{baseUrl}}/api/breeds
Content-Type: application/json

{
  "name":"persian cat",
  "species_id":"c7d785c8-28a9-495e-af91-88801a326d77"
}

### get all breeds
GET {{baseUrl}}/api/breeds

### get all breeds by species
GET {{baseUrl}}/api/breeds/species/c7d785c8-28a9-495e-af91-88801a326d77

### update breeds
PATCH {{baseUrl}}/api/breeds/f8c41029-acb1-44b5-b5cf-e61324b10f26
Content-Type: application/json

{
  "name":"russian cat"
}

### delete breeds
DELETE {{baseUrl}}/api/breeds/f8c41029-acb1-44b5-b5cf-e61324b10f26
